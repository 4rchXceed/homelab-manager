{
    "config": {
        "servicesFolder": "../services-compose",
        "database": {
            "postgresHost": "db",
            "postgresPort": "5432",
            "postgresDbName": "homelabmanager",
            "postgresUsername": "postgres",
            "postgresPassword": "Passw0rd"
        },
        "net": {
            "serverPort": 4398,
            "fileServerPort": 4399
        },
        "unixSocketPath": "/tmp/homelabmanager.sock",
        "startupTimeout": 120,
        "keepaliveInterval": 5
    },
    "generators": {
        "htpasswd": {
            "installDeps": "apt install -y apache2-utils",
            "base": "bash",
            "run": "htpasswd -c -b $ARG1 $ARG2 $ARG3",
            "needsRoot": true
        },
        "replaceFile": {
            "base": "bash",
            "run": "sed -i -e \"s/$ARG1/$ARG2/g\" $ARG3"
        }
    },
    "services": {
        "crowdsec": {
            "name": "Crowdsec",
            "data": [
                "./crowdsec/acquis.yaml",
                "./crowdsec-db",
                "./crowdsec-config"
            ],
            "configFiles": []
        },
        "reverse-proxy": {
            "name": "Reverse Proxy",
            "data": ["./letsencrypt/"],
            "configFiles": [
                {
                    "path": ".htpasswd",
                    "generators": [
                        {
                            "generator": "htpasswd",
                            "generatorArgs": [
                                ".htpasswd",
                                {
                                    "type": "userVar",
                                    "name": "Username for the admin section of Nginx",
                                    "id": "username_main"
                                },
                                {
                                    "type": "userVar",
                                    "name": "Password for the admin section Nginx",
                                    "id": "password_main"
                                }
                            ]
                        }
                    ]
                },
                {
                    "path": "crowdsec-nginx-bouncer.conf",
                    "generators": [
                        {
                            "generator": "replaceFile",
                            "generatorArgs": [
                                "your-api-url",
                                {
                                    "type": "ip",
                                    "get": "crowdsec",
                                    "raiseNotFound": false
                                },
                                "crowdsec-nginx-bouncer.conf"
                            ]
                        },
                        {
                            "generator": "replaceFile",
                            "generatorArgs": [
                                "your-api",
                                {
                                    "type": "userVar",
                                    "name": "The crowdsec nginx bouncer API key",
                                    "id": "nginx_bouncer_api_key"
                                },
                                "crowdsec-nginx-bouncer.conf"
                            ]
                        }
                    ]
                }
            ]
        }
    },
    "servers": [
        {
            "id": "main",
            "name": "Main Server",
            "description": "...",
            "ip": "192.168.122.219"
        }
    ]
}

{
    "config": {
        "servicesFolder": "../services-compose",
        "database": {
            "postgresHost": "db",
            "postgresPort": "5432",
            "postgresDbName": "homelabmanager",
            "postgresUsername": "postgres",
            "postgresPassword": "Passw0rd"
        },
        "net": {
            "serverPort": 4398,
            "fileServerPort": 4399
        },
        "unixSocketPath": "/tmp/homelabmanager.sock",
        "startupTimeout": 120,
        "keepaliveInterval": 5
    },
    "generators": {
        "replaceFile": {
            "base": "bash",
            "run": "sed -i -e \"s/$ARG1/$ARG2/g\" $ARG3"
        },
        "nextcloudOcc": {
            "base": "bashUnsandboxed",
            "run": "docker compose exec -it $ARG1 php --define apc.enable_cli=1 occ $ARG2$ARG3$ARG4$ARG5"
        }
    },
    "services": {
        "main-website": {
            "name": "Main Website (WebDash)",
            "data": ["./server/db", "./server/config"],
            "configFiles": [
                {
                    "path": ".env",
                    "generators": [
                        {
                            "generator": "replaceFile",
                            "generatorArgs": [
                                "WEBSITE_PORT_VAR",
                                {
                                    "type": "userVar",
                                    "name": "Main website port (example: 9005)",
                                    "id": "main_website_port"
                                },
                                ".env"
                            ]
                        }
                    ]
                }
            ]
        },
        "nextcloud": {
            "name": "Cloud (nextcloud)",
            "data": ["./cloud-data", "./db"],
            "configFiles": [
                {
                    "path": ".env",
                    "generators": [
                        {
                            "generator": "replaceFile",
                            "generatorArgs": [
                                "DB_PASSWORD_VAR",
                                {
                                    "type": "userVar",
                                    "name": "Nextcloud db password",
                                    "id": "cloud_db_password"
                                },
                                ".env"
                            ]
                        },
                        {
                            "generator": "replaceFile",
                            "generatorArgs": [
                                "ADMIN_USER_VAR",
                                {
                                    "type": "userVar",
                                    "name": "Nextcloud admin username",
                                    "id": "cloud_admin_user"
                                },
                                ".env"
                            ]
                        },
                        {
                            "generator": "replaceFile",
                            "generatorArgs": [
                                "ADMIN_PASSWORD_VAR",
                                {
                                    "type": "userVar",
                                    "name": "Nextcloud admin password",
                                    "id": "cloud_admin_password"
                                },
                                ".env"
                            ]
                        },
                        {
                            "generator": "replaceFile",
                            "generatorArgs": [
                                "DB_ROOT_PASSWORD_VAR",
                                {
                                    "type": "userVar",
                                    "name": "Nextcloud *ROOT* db password",
                                    "id": "cloud_root_db_password"
                                },
                                ".env"
                            ]
                        },
                        {
                            "generator": "replaceFile",
                            "generatorArgs": [
                                "CLOUD_PORT",
                                {
                                    "type": "userVar",
                                    "name": "Cloud port (example: 3939)",
                                    "id": "cloud_port"
                                },
                                ".env"
                            ]
                        },
                        {
                            "generator": "replaceFile",
                            "generatorArgs": [
                                "CLOUD_SUBFOLDER_VAR",
                                {
                                    "type": "userVar",
                                    "name": "Cloud subpath (example: cloud)",
                                    "id": "cloud_subpath"
                                },
                                ".env"
                            ]
                        },
                        {
                            "generator": "nextcloudOcc",
                            "generatorArgs": [
                                "app",
                                "config:system:set trusted_domains 0 --value=",
                                {
                                    "type": "ip",
                                    "get": "nextcloud",
                                    "raiseNotFound": false
                                },
                                ""
                            ]
                        },
                        {
                            "generator": "nextcloudOcc",
                            "generatorArgs": [
                                "app",
                                "config:system:set overwriteprotocol --value=",
                                "http://",
                                ""
                            ]
                        },
                        {
                            "generator": "nextcloudOcc",
                            "generatorArgs": [
                                "app",
                                "config:system:set overwritewebroot --value=/",
                                {
                                    "type": "userVar",
                                    "name": "Cloud subpath (example: cloud)",
                                    "id": "cloud_subpath"
                                },
                                ""
                            ]
                        },
                        {
                            "generator": "nextcloudOcc",
                            "generatorArgs": [
                                "app",
                                "config:system:set overwritehost --value=",
                                {
                                    "type": "ip",
                                    "get": "reverse-proxy",
                                    "raiseNotFound": false
                                },
                                ":",
                                {
                                    "type": "userVar",
                                    "name": "Reverse proxy port",
                                    "id": "reverse_proxy_port"
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        "reverse-proxy": {
            "name": "Nginx Reverse Proxy",
            "data": [],
            "configFiles": [
                {
                    "path": ".env",
                    "generators": [
                        {
                            "generator": "replaceFile",
                            "generatorArgs": [
                                "REVERSE_PROXY_PORT_VAR",
                                {
                                    "type": "userVar",
                                    "name": "Reverse proxy port",
                                    "id": "reverse_proxy_port"
                                },
                                ".env"
                            ]
                        }
                    ]
                },
                {
                    "path": "nginx.conf",
                    "whenConfigUpdated": [
                        "docker compose exec nginx nginx -s reload"
                    ],
                    "reloadTimeout": 5,
                    "generators": [
                        {
                            "generator": "replaceFile",
                            "generatorArgs": [
                                "MAIN-WEBSITE-HOST",
                                {
                                    "type": "ip",
                                    "get": "main-website",
                                    "raiseNotFound": false
                                },
                                "nginx.conf"
                            ]
                        },
                        {
                            "generator": "replaceFile",
                            "generatorArgs": [
                                "CLOUD-HOST",
                                {
                                    "type": "ip",
                                    "get": "nextcloud",
                                    "raiseNotFound": false
                                },
                                "nginx.conf"
                            ]
                        },
                        {
                            "generator": "replaceFile",
                            "generatorArgs": [
                                "CLOUD-SUBDIR",
                                {
                                    "type": "userVar",
                                    "name": "Cloud subpath (example: cloud)",
                                    "id": "cloud_subpath"
                                },
                                "nginx.conf"
                            ]
                        },
                        {
                            "generator": "replaceFile",
                            "generatorArgs": [
                                "CLOUD-PORT",
                                {
                                    "type": "userVar",
                                    "name": "Cloud port (example: 3939)",
                                    "id": "cloud_port"
                                },
                                "nginx.conf"
                            ]
                        },
                        {
                            "generator": "replaceFile",
                            "generatorArgs": [
                                "MAIN-WEBSITE-PORT",
                                {
                                    "type": "userVar",
                                    "name": "Main website port (example: 9005)",
                                    "id": "main_website_port"
                                },
                                "nginx.conf"
                            ]
                        }
                    ]
                }
            ]
        }
    },
    "servers": [
        {
            "id": "main",
            "name": "Main Server",
            "description": "...",
            "ip": "192.168.1.249"
        }
    ]
}

{
    "config": {
        "_import": "../general"
    },
    "generators": {
        "createFile": {
            "_import": "../generators/createFile"
        }
    },
    "services": {
        "14_test-var-set": {
            "name": "Test Service",
            "configFiles": [
                {
                    "path": "config.txt",
                    "generators": [
                        {
                            "generator": "createFile",
                            "generatorArgs": [
                                {
                                    "type": "userVar",
                                    "id": "testVar",
                                    "name": "Test var"
                                },
                                "config.txt"
                            ]
                        }
                    ]
                }
            ]
        }
    },
    "servers": [
        {
            "_import": "../servers/1"
        }
    ]
}
